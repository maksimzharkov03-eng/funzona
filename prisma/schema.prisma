generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  login     String   @unique
  password  String
  createdAt DateTime @default(now())
}

model Order {
  id           Int      @id @default(autoincrement())
  telegram     String
  payment      String
  comment      String?
  status       String   @default("Ожидает оплаты")
  productName  String   @default("Товар не указан")
  productPrice String   @default("0 ₽")
  createdAt    DateTime @default(now())
}

model Product {
  id          Int     @id @default(autoincrement())
  name        String
  category    String
  description String
  price       String
  image       String?
}

model Game {
  id          Int      @id @default(autoincrement())
  title       String
  image       String
  platform    String
  region      String
  originalPrice Float
  currency    String
  rubPrice    Int
  createdAt   DateTime @default(now())
}