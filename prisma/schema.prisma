generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  login     String   @unique
  password  String
  role      String   @default("user")
  createdAt DateTime @default(now())
}

model Order {
  id           Int      @id @default(autoincrement())
  telegram      String
  payment       String
comment       String?
  status       String   @default("Ожидает оплаты")
  productName  String   @default("Товар не указан")
  productPrice String   @default("0 ₽")
  deliveryData         String?
  autoDeliveryProvider String?
  autoDeliveryCostUsd  Float?
  autoDeliveryRevenueRub Int?
  autoDeliveryAt       DateTime?
  userLogin            String?
  createdAt    DateTime @default(now())
}

model Product {
  id          Int     @id @default(autoincrement())
  name        String
  category    String
  description String
  price       String
  image       String?
}

model Game {
  id              Int      @id @default(autoincrement())
  title           String
  image           String
  platform        String
  region          String
  originalPrice   Float
  currency        String
  rubPrice        Int
  oldRubPrice     Int?
  discountPercent Int?
  genre           String?
  publisher       String?
  releaseDate     DateTime?
  edition         String?
  badge           String?
  description     String?
  isFeatured      Boolean  @default(false)
  createdAt       DateTime @default(now())
}


model ChatMessage {
  id          Int      @id @default(autoincrement())
  userLogin   String
  sender      String
  text        String
  readByAdmin Boolean  @default(false)
  readByUser  Boolean  @default(false)
  createdAt   DateTime @default(now())

  @@index([userLogin, createdAt])
}


model AutoDeliveryLog {
  id        Int      @id @default(autoincrement())
  orderId   Int?
  provider  String   @default("NS Gifts")
  status    String
  message   String
  costUsd   Float?
  createdAt DateTime @default(now())

  @@index([orderId, createdAt])
  @@index([status, createdAt])
}


model NsBalanceSnapshot {
  id         Int      @id
  balanceUsd Float
  source     String   @default("vps")
  checkedAt  DateTime
  updatedAt  DateTime @updatedAt
}

model Review {
  id        Int      @id @default(autoincrement())
  userLogin   String?  @unique
  name      String
  rating    Int      @default(5)
  text      String
  status      String   @default("На проверке")
  isPublished Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([createdAt])

  @@index([isPublished, createdAt])
  @@index([status, createdAt])
}
