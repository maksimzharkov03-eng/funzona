generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id       Int    @id @default(autoincrement())
  login    String @unique
  password String

  orders Order[]
}

model Product {
  id          Int     @id @default(autoincrement())
  name        String
  category    String
  description String
  price       String
  image       String?

  orders Order[]
}

model Order {
  id        Int      @id @default(autoincrement())
  status    String
  telegram  String
  payment   String
  comment   String
  createdAt DateTime @default(now())

  userId    Int?
  productId Int?

  user    User?    @relation(fields: [userId], references: [id])
  product Product? @relation(fields: [productId], references: [id])
}
